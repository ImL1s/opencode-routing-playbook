        },
        "sonnet-4.5-thinking": {
          "name": "Claude 4.5 Sonnet (Thinking)"
        }
      },
      "name": "Cursor Agent (ACP stdin)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      }
    },
    "google": {
