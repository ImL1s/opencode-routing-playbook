{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CLAUDE.md",
    "AGENTS.md",
    "GEMINI.md"
  ],
  "mcp": {
    "brightData": {
      "command": [
        "npx",
        "-y",
        "@brightdata/mcp"
      ],
      "enabled": true,
      "environment": {
        "API_TOKEN": "${BRIGHTDATA_API_TOKEN}",
        "PRO_MODE": "true"
      },
      "type": "local"
    },
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "firebase": {
      "command": [
        "npx",
        "-y",
        "firebase-tools@latest",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "mobile-mcp": {
      "command": [
        "npx",
        "@mobilenext/mobile-mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "openai/gpt-5.5",
  "permission": {
    "*": "allow",
    "bash": "allow",
    "edit": "allow"
  },
  "plugin": [
    "opencode-antigravity-auth@latest",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "cursor": {
      "models": {
        "auto": {
          "name": "Auto"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus"
        },
        "opus-4.6-thinking": {
          "name": "Claude 4.6 Opus (Thinking)"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "${PROVIDER_API_KEY}",
        "baseURL": "http://127.0.0.1:8765/v1"
      }
    },
    "cursor-acp": {
      "models": {
        "auto": {
          "name": "Auto"
        },
        "composer-1": {
          "name": "Composer 1"
